# =============================================================================
# OBSIDIAN DOWNLOADER - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (Required)
# -----------------------------------------------------------------------------
# Obsidian account credentials
OBSIDIAN_EMAIL=
OBSIDIAN_PASSWORD=

# -----------------------------------------------------------------------------
# Telegram Notifications (Optional)
# -----------------------------------------------------------------------------
# Get token from @BotFather and user ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# -----------------------------------------------------------------------------
# Browser Configuration (Optional)
# -----------------------------------------------------------------------------
# Set to true to run browser in visible mode for debugging
DEBUG=false

# User-Agent string for browser
# Default: Windows 10 Chrome 120
WINDOWS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# -----------------------------------------------------------------------------
# Paths Configuration (Optional)
# -----------------------------------------------------------------------------
# All paths are relative to project root if not absolute
# Default: ./auth.json
AUTH_STATE_FILE=./auth.json

# Default: ./downloads
DOWNLOADS_DIR=./downloads

# Default: ./database.db
DATABASE_PATH=./database.db

# Default: ./app.log
LOG_FILE=./app.log

# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------
# Log levels: error, warn, info, debug (default: info)
LOG_LEVEL=info

# Maximum log file size in bytes before rotation (default: 10MB)
LOG_MAX_SIZE=10485760

# Number of rotated log files to keep (default: 5)
LOG_MAX_FILES=5

# -----------------------------------------------------------------------------
# Scheduler Configuration (Optional)
# -----------------------------------------------------------------------------
# Enable/disable automatic scheduler (default: true)
ENABLE_CRON=true

# Cron schedule for automatic downloads
# Default: every 6 hours (0 */6 * * *)
# Examples:
#   0 9 * * *     - Every day at 9 AM
#   0 */4 * * *   - Every 4 hours
#   0 0 * * 1     - Every Monday at midnight
#   0 0 * * *     - Every day at midnight
CRON_SCHEDULE=0 */6 * * *

# -----------------------------------------------------------------------------
# Retry Configuration (Optional)
# -----------------------------------------------------------------------------
# Maximum number of retry attempts (default: 3)
RETRY_MAX_RETRIES=3

# Base delay between retries in ms (default: 1000)
RETRY_BASE_DELAY=1000

# Maximum delay between retries in ms (default: 30000)
RETRY_MAX_DELAY=30000

# Exponential backoff factor (default: 2)
RETRY_EXPONENTIAL_FACTOR=2

# Add random jitter to delays (default: true)
RETRY_JITTER=true

# Timeout for navigation operations in ms (default: 30000)
TIMEOUT_NAVIGATION=30000

# Timeout for selector waits in ms (default: 10000)
TIMEOUT_SELECTOR=10000

# Timeout for download operations in ms (default: 60000)
TIMEOUT_DOWNLOAD=60000

# Timeout for actions (click/fill) in ms (default: 15000)
TIMEOUT_ACTION=15000

# Timeout for screenshots in ms (default: 10000)
TIMEOUT_SCREENSHOT=10000

# Timeout for storage state operations in ms (default: 15000)
TIMEOUT_STORAGE_STATE=15000

# -----------------------------------------------------------------------------
# Database Configuration (Optional)
# -----------------------------------------------------------------------------
# Enable download history tracking (default: true)
ENABLE_DOWNLOAD_HISTORY=true

# Hours to keep download history for skip protection (default: 24)
DOWNLOAD_SKIP_HOURS=24
